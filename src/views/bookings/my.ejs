<%- include("../partials/header") %>

<section class="page-head reveal">
  <div>
    <p class="eyebrow">Attendee Panel</p>
    <h1>My Bookings</h1>
  </div>
  <a href="/events" class="btn btn-outline">Find More Events</a>
</section>

<% if (!bookings.length) { %>
  <section class="empty-state reveal">
    <h2>No bookings yet</h2>
    <p>Reserve your first event seat now.</p>
    <a href="/events" class="btn btn-primary">Browse Events</a>
  </section>
<% } else { %>
  <section class="event-grid">
    <% bookings.forEach((booking) => { %>
      <article class="event-card reveal">
        <p class="event-meta"><%= dayjs(booking.starts_at).format("MMM D, YYYY h:mm A") %> • <%= booking.location %></p>
        <h3><a href="/events/<%= booking.event_id %>"><%= booking.title %></a></h3>
        <p>You booked <strong><%= booking.quantity %></strong> seat(s).</p>
        <form action="/bookings/<%= booking.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Cancel this booking?');">
          <button type="submit" class="btn btn-danger">Cancel Booking</button>
        </form>
      </article>
    <% }) %>
  </section>
<% } %>

<%- include("../partials/footer") %>
