<%- include("partials/header") %>

<section class="auth-card reveal">
  <h1>Welcome back</h1>
  <p>Log in to manage your events and bookings.</p>

  <form action="/login" method="POST" class="form-grid">
    <label>
      Email
      <input type="email" name="email" required value="<%= (input && input.email) || '' %>" />
    </label>
    <label>
      Password
      <input type="password" name="password" required />
    </label>
    <button type="submit" class="btn btn-primary">Login</button>
  </form>

  <p class="auth-switch">No account yet? <a href="/register">Create one</a>.</p>
</section>

<%- include("partials/footer") %>
