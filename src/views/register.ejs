<%- include("partials/header") %>

<section class="auth-card reveal">
  <h1>Create your account</h1>
  <p>Start hosting and booking events in under a minute.</p>

  <form action="/register" method="POST" class="form-grid">
    <label>
      Full name
      <input type="text" name="name" required value="<%= (input && input.name) || '' %>" />
    </label>
    <label>
      Email
      <input type="email" name="email" required value="<%= (input && input.email) || '' %>" />
    </label>
    <label>
      Password
      <input type="password" name="password" required minlength="6" />
    </label>
    <button type="submit" class="btn btn-primary">Create Account</button>
  </form>

  <p class="auth-switch">Already registered? <a href="/login">Login</a>.</p>
</section>

<%- include("partials/footer") %>
