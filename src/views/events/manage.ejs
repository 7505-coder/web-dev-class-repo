<%- include("../partials/header") %>

<section class="page-head reveal">
  <div>
    <p class="eyebrow">Organizer Dashboard</p>
    <h1>My Events</h1>
  </div>
  <a href="/events/new" class="btn btn-primary">New Event</a>
</section>

<% if (!events.length) { %>
  <section class="empty-state reveal">
    <h2>No events yet</h2>
    <p>Create your first event to start accepting bookings.</p>
    <a href="/events/new" class="btn btn-primary">Create Event</a>
  </section>
<% } else { %>
  <section class="table-wrap reveal">
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Start</th>
          <th>Location</th>
          <th>Seats</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach((event) => { %>
          <tr>
            <td><a href="/events/<%= event.id %>"><%= event.title %></a></td>
            <td><%= dayjs(event.starts_at).format("MMM D, YYYY h:mm A") %></td>
            <td><%= event.location %></td>
            <td><%= event.seats_available %>/<%= event.capacity %></td>
            <td class="actions">
              <a href="/events/<%= event.id %>/edit" class="btn btn-sm btn-outline">Edit</a>
              <form action="/events/<%= event.id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirm('Delete this event? This will remove all bookings.');">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
<% } %>

<%- include("../partials/footer") %>
