<%- include("../partials/header") %>

<section class="form-card reveal">
  <h1>Edit Event</h1>

  <form action="/events/<%= event.id %>?_method=PUT" method="POST" class="form-grid">
    <label>
      Title
      <input type="text" name="title" required value="<%= event.title %>" />
    </label>
    <label>
      Description
      <textarea name="description" rows="5" required><%= event.description %></textarea>
    </label>
    <label>
      Location
      <input type="text" name="location" required value="<%= event.location %>" />
    </label>
    <div class="split-2">
      <label>
        Starts At
        <input type="datetime-local" name="starts_at" required value="<%= event.starts_at %>" />
      </label>
      <label>
        Ends At
        <input type="datetime-local" name="ends_at" required value="<%= event.ends_at %>" />
      </label>
    </div>
    <label>
      Capacity
      <input type="number" name="capacity" min="1" required value="<%= event.capacity %>" />
    </label>
    <button type="submit" class="btn btn-primary">Save Changes</button>
  </form>
</section>

<%- include("../partials/footer") %>
