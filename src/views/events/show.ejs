<%- include("../partials/header") %>

<article class="event-detail reveal">
  <p class="eyebrow">Hosted by <%= event.owner_name %></p>
  <h1><%= event.title %></h1>

  <div class="detail-grid">
    <div>
      <h4>When</h4>
      <p><%= dayjs(event.starts_at).format("MMM D, YYYY h:mm A") %> to <%= dayjs(event.ends_at).format("MMM D, YYYY h:mm A") %></p>
    </div>
    <div>
      <h4>Where</h4>
      <p><%= event.location %></p>
    </div>
    <div>
      <h4>Capacity</h4>
      <p><strong><%= event.seats_available %></strong> seats available of <%= event.capacity %></p>
    </div>
  </div>

  <p class="description"><%= event.description %></p>

  <% if (currentUser && currentUser.id !== event.owner_id) { %>
    <% if (existingBooking) { %>
      <div class="alert alert-success">You already booked <strong><%= existingBooking.quantity %></strong> seat(s) for this event.</div>
    <% } else { %>
      <form method="POST" action="/bookings/<%= event.id %>" class="booking-form">
        <label>
          Seats
          <input type="number" name="quantity" min="1" max="20" value="1" required />
        </label>
        <button type="submit" class="btn btn-primary">Book Now</button>
      </form>
    <% } %>
  <% } else if (!currentUser) { %>
    <p><a href="/login">Log in</a> to book this event.</p>
  <% } %>
</article>

<%- include("../partials/footer") %>
