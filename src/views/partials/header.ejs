<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | EventHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Bricolage+Grotesque:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="bg-aurora"></div>
  <header class="site-header">
    <div class="container nav-wrap">
      <a href="/" class="brand">EventHub</a>
      <nav class="nav-links">
        <a href="/events">Browse</a>
        <% if (currentUser) { %>
          <a href="/events/new">Create</a>
          <a href="/events/manage">My Events</a>
          <a href="/bookings/my">My Bookings</a>
          <form method="POST" action="/logout" class="inline-form">
            <button type="submit" class="btn btn-ghost">Logout</button>
          </form>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register" class="btn btn-primary">Sign Up</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container page-content">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
